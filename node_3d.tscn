[sub_resource type="GDScript" id="GDScript_a202f"]
resource_name = "Cris"
script/source = "extends CharacterBody3D

const SPEED = 3
const JUMP_HEIGHT = 5
var cam_speed = 2
var offset_camera

func _ready() -> void:
	
	offset_camera = %camera.global_position - global_position


func _process(delta: float) -> void:
	
	
	
	velocity += get_gravity() * delta
	
	if Input.is_action_just_pressed(\"ui_accept\") and is_on_floor():
		velocity.y = JUMP_HEIGHT
	
	var direcao = Input.get_vector(\"a\",\"d\",\"w\",\"s\")
	
	velocity = Vector3(direcao.x * SPEED,velocity.y,direcao.y * SPEED).rotated(Vector3.UP,%camera.rotation.y)
	
	if direcao.length() > 0:
		var vetor_rotacionado = Vector2(direcao.y,direcao.x).rotated(%camera.rotation.y)
		rotation.y = vetor_rotacionado.angle()
		
		

	
	if Input.is_action_pressed(\"ui_right\"):
		%camera.rotation.y -= cam_speed * delta

	if Input.is_action_pressed(\"ui_left\"):
		%camera.rotation.y += cam_speed * delta
	if Input.is_action_pressed(\"ui_up\"):
		%camera.rotation.x -= cam_speed * delta

	if Input.is_action_pressed(\"ui_down\"):
		%camera.rotation.x += cam_speed * delta
	var offset = offset_camera
	offset = offset.rotated(Vector3.RIGHT, %camera.rotation.x)
	offset = offset.rotated(Vector3.UP, %camera.rotation.y)
	
	%camera.rotation.x = clamp(%camera.rotation.x, -0.5, 0)

	%camera.global_position = global_position + offset
	
	move_and_slide()
"

